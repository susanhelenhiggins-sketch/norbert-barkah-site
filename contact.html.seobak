        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Norbert Barkah. All rights reserved.</p>
        <p style="font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 0.5rem;">Photography by Faith Hamberg, Heartsake Photography</p>
      </div>
    </div>
  </footer>

  <script src="js/main.js"></script>
</body>
</html>
