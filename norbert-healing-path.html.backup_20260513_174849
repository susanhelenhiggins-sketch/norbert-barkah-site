  <script>
    // ---- Journal fetch and render ----
    // All API-provided content rendered via createElement + textContent.
    // innerHTML used only for fixed hardcoded status messages.

    const API_URL = 'https://tracker.norbertbarkah.com/api/journal';

    // Format YYYY-MM-DD as "May 13, 2026"
    function formatDate(raw) {
      if (!raw) return '';
      const parts = raw.split('-');
      if (parts.length !== 3) return raw;
      const d = new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
      if (isNaN(d.getTime())) return raw;
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    // Safe ID: prefix entry uuid or integer id
    function safeEntryId(id) {
      // Replace anything that is not alphanumeric or hyphen
      const clean = String(id).replace(/[^a-zA-Z0-9-]/g, '-');
      return 'journal-entry-' + clean;
    }

    // Build one sidebar/toggle list item using textContent only
    function buildNavItem(entry, listClass) {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = '#' + safeEntryId(entry.id);

      const dateSpan = document.createElement('span');
      dateSpan.textContent = formatDate(entry.date);

      const titleSpan = document.createElement('span');
      titleSpan.textContent = entry.title || '';

      if (listClass === 'sidebar') {
        dateSpan.className = 'sidebar-entry-date';
        titleSpan.className = 'sidebar-entry-title';
      } else {
        dateSpan.className = 'toggle-entry-date';
        titleSpan.className = 'toggle-entry-title';
      }

      a.appendChild(dateSpan);
      a.appendChild(titleSpan);
      li.appendChild(a);
      return li;
    }

    // Build one journal entry article using createElement + textContent only
    function buildEntry(entry) {
      const article = document.createElement('article');
      article.className = 'journal-entry fade-in';
      article.id = safeEntryId(entry.id);

      const dateDiv = document.createElement('div');
      dateDiv.className = 'entry-date';
      dateDiv.textContent = formatDate(entry.date);

      const titleH2 = document.createElement('h2');
      titleH2.className = 'entry-title';
      titleH2.textContent = entry.title || '';

      const bodyDiv = document.createElement('div');
      bodyDiv.className = 'entry-body';

      // Split body on double newlines into paragraphs.
      // Each paragraph rendered with textContent -- no HTML injection.
      const rawBody = entry.body || '';
      const paragraphs = rawBody.split(/
\s*
/);
      paragraphs.forEach(function(chunk) {
        const trimmed = chunk.trim();
        if (!trimmed) return;
        const p = document.createElement('p');
        p.textContent = trimmed;
        bodyDiv.appendChild(p);
      });

      // If body had no double newlines, split on single newlines
      if (bodyDiv.children.length === 0 && rawBody.trim()) {
        const lines = rawBody.split('
');
        lines.forEach(function(line) {
          const trimmed = line.trim();
          if (!trimmed) return;
          const p = document.createElement('p');
          p.textContent = trimmed;
          bodyDiv.appendChild(p);
        });
      }

      // Fallback: if still empty, render as single paragraph
      if (bodyDiv.children.length === 0 && rawBody.trim()) {
        const p = document.createElement('p');
        p.textContent = rawBody.trim();
        bodyDiv.appendChild(p);
      }

      article.appendChild(dateDiv);
      article.appendChild(titleH2);
      article.appendChild(bodyDiv);
      return article;
    }

    // Main fetch and render
    async function loadJournal() {
      const entriesEl = document.getElementById('journal-entries');
      const statusEl = document.getElementById('journal-status');
      const sidebarList = document.getElementById('journal-sidebar-list');
      const toggleList = document.getElementById('journal-toggle-list');

      try {
        const response = await fetch(API_URL);
        if (!response.ok) throw new Error('API returned ' + response.status);
        const entries = await response.json();

        // Remove loading message
        if (statusEl) statusEl.remove();

        if (!Array.isArray(entries) || entries.length === 0) {
          // Empty state -- hardcoded string, innerHTML is safe here
          const msg = document.createElement('p');
          msg.className = 'journal-status';
          msg.textContent = "Norbert's journal entries are on the way. Check back soon.";
          entriesEl.appendChild(msg);
          return;
        }

        // Render entries and nav lists
        entries.forEach(function(entry) {
          // Entry article
          entriesEl.appendChild(buildEntry(entry));
          // Sidebar nav item
          sidebarList.appendChild(buildNavItem(entry, 'sidebar'));
          // Mobile toggle nav item
          toggleList.appendChild(buildNavItem(entry, 'toggle'));
        });

      } catch (err) {
        // Error state -- hardcoded string, innerHTML is safe here
        if (statusEl) {
          statusEl.textContent = 'The forest is quiet right now. Please try again in a moment.';
        }
        console.error('Journal fetch error:', err);
      }
    }

    // Mobile toggle button
    document.addEventListener('DOMContentLoaded', function() {
      loadJournal();

      const btn = document.getElementById('journal-toggle-btn');
      const list = document.getElementById('journal-toggle-list');
      if (btn && list) {
        btn.addEventListener('click', function() {
          const isOpen = list.classList.contains('open');
          list.classList.toggle('open', !isOpen);
          btn.setAttribute('aria-expanded', String(!isOpen));
          list.setAttribute('aria-hidden', String(isOpen));
          btn.textContent = isOpen ? 'Jump to an entry' : 'Close entry list';
        });
      }
    });
  </script>

  <script src="js/main.js"></script>

</body>
