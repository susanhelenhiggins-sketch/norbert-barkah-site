  <style>
    /* ---- Healing Path page-specific styles ---- */

    .healing-hero {
      background-image: url('images/enchanted-forest-hero.jpg');
      background-size: cover;
      background-position: center;
      min-height: 460px; padding-top: 140px;
      display: flex;
      align-items: center;
      position: relative;
    }

    .healing-hero-overlay {
      position: absolute;
      inset: 0;
      background: rgba(30, 55, 45, 0.82);
    }

    .healing-hero-content {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 4.5rem 2rem;
      max-width: 780px;
      margin: 0 auto;
      width: 100%;
    }

    .healing-hero-content h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 5vw, 3.6rem);
      color: #FAF6F0;
      font-weight: 600;
      margin-bottom: 1.75rem;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.45);
    }

    .healing-intro {
      font-family: 'Nunito', sans-serif;
      font-size: 1.1rem;
      line-height: 1.95;
      color: rgba(250, 246, 240, 0.90);
      text-shadow: 0 1px 5px rgba(0, 0, 0, 0.3);
      max-width: 660px;
      margin: 0 auto 1.5rem;
    }


    .healing-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.2rem;
      color: rgba(196, 163, 90, 0.88);
      text-align: center;
      max-width: 600px;
      margin: 0 auto 1.5rem;
      line-height: 1.75;
    }
    .gold-rule {
      border: none;
      border-top: 1px solid rgba(196, 163, 90, 0.45);
      width: 80px;
      margin: 1.75rem auto;
    }

    .journal-section {
      background: #FAF6F0;
      padding: 5rem 0;
    }

    .journal-entries {
      max-width: 760px;
      margin: 0 auto;
    }

    .journal-entry {
      background: #ffffff;
      border-radius: 16px;
      padding: 2.75rem 3rem;
      margin-bottom: 2.5rem;
      box-shadow: 0 2px 18px rgba(44, 74, 62, 0.07);
      border-left: 4px solid #C4A35A;
    }

    .entry-date {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem;
      color: #C4A35A;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.6rem;
    }

    .entry-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.85rem;
      color: #2C4A3E;
      font-weight: 600;
      margin-bottom: 1.25rem;
      line-height: 1.3;
    }

    .entry-body p {
      font-family: 'Nunito', sans-serif;
      font-size: 1.05rem;
      line-height: 1.88;
      color: #3a3a3a;
      margin-bottom: 1rem;
    }

    .entry-body p:last-child {
      margin-bottom: 0;
    }

    .healing-closing {
      background: #2C4A3E;
      padding: 4rem 2rem;
      text-align: center;
    }

    .healing-closing p {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: clamp(1.2rem, 2.5vw, 1.45rem);
      color: rgba(250, 246, 240, 0.88);
      max-width: 620px;
      margin: 0 auto;
      line-height: 1.85;
    }

    .healing-closing .closing-credit {
      font-family: 'Nunito', sans-serif;
      font-style: normal;
      font-size: 0.9rem;
      color: rgba(196, 163, 90, 0.75);
      margin-top: 1.25rem;
    }

    @media (max-width: 700px) {
      .journal-entry {
        padding: 1.75rem 1.5rem;
      }

      .journal-section {
        padding: 3.5rem 0;
      }
    }

    /* ---- Journal layout: sidebar + entries ---- */
    .journal-layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 3rem;
      max-width: 1100px;
      margin: 0 auto;
      align-items: start;
    }

    .journal-sidebar {
      position: sticky;
      top: 100px;
    }

    .journal-sidebar-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.85rem;
      color: #C4A35A;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    .journal-sidebar-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .journal-sidebar-list li {
      margin-bottom: 0.85rem;
      border-left: 2px solid rgba(196, 163, 90, 0.25);
      padding-left: 0.85rem;
    }

    .journal-sidebar-list a {
      text-decoration: none;
      display: block;
    }

    .journal-sidebar-list .sidebar-entry-date {
      font-family: 'Nunito', sans-serif;
      font-size: 0.75rem;
      color: #C4A35A;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      display: block;
      margin-bottom: 0.1rem;
    }

    .journal-sidebar-list .sidebar-entry-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      color: #2C4A3E;
      line-height: 1.3;
    }

    .journal-sidebar-list a:hover .sidebar-entry-title {
      color: #C4A35A;
    }

    /* ---- Mobile collapsible toggle ---- */
    .journal-mobile-toggle {
      display: none;
    }

    .journal-toggle-btn {
      background: none;
      border: 1px solid rgba(196, 163, 90, 0.6);
      color: #2C4A3E;
      font-family: 'Nunito', sans-serif;
      font-size: 0.9rem;
      padding: 0.6rem 1.25rem;
      border-radius: 20px;
      cursor: pointer;
      margin-bottom: 1rem;
      width: 100%;
    }

    .journal-toggle-list {
      display: none;
      list-style: none;
      padding: 0;
      margin: 0 0 2rem;
      background: #ffffff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(44, 74, 62, 0.07);
      overflow: hidden;
    }

    .journal-toggle-list.open {
      display: block;
    }

    .journal-toggle-list li a {
      display: block;
      padding: 0.85rem 1.25rem;
      text-decoration: none;
      border-bottom: 1px solid rgba(196, 163, 90, 0.12);
    }

    .journal-toggle-list li:last-child a {
      border-bottom: none;
    }

    .journal-toggle-list .toggle-entry-date {
      font-family: 'Nunito', sans-serif;
      font-size: 0.75rem;
      color: #C4A35A;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      display: block;
    }

    .journal-toggle-list .toggle-entry-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem;
      color: #2C4A3E;
    }

    /* ---- Status messages ---- */
    .journal-status {
